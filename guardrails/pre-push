#!/usr/bin/env bash
# pre-push — track-coach push gate (the live-spec pack's 5-gate shape, adapted to this host).
# Installed by guardrails/install.sh into .git/hooks/pre-push. Blocks a push unless every
# blocking gate passes. See .live-spec/profile.md for the host's stated deviations.
#
# Gates (pack shape → track-coach adaptation):
#   a. fresh review    → WARNING ONLY here: track-coach's prover cadence is per-feature
#                        CROSS-LINK + milestone audits, not per-push same-day (host profile).
#                        The hook still tells you when no prover record is dated today.
#   b. tests green     → the full pytest suite (includes the completeness gate INV-45/46
#                        and traceability tests — pack gate (c) rides on these).
#   c. anchors owned   → covered by (b): tests/test_traceability.py.
#   d. coverage walked → no unchecked `- [ ]` boxes in docs/TEST_MATRIX.md (the checklist
#                        is a prose walk in §8; boxes would still block if ever added).
#   e. prototype fence → a prod file must not reference anything under prototype/ (passes
#                        if no prototype/ dir exists — none does today).
#   f. tests-present   → code touched ⇒ a test touched (scripts/guardrails.py check 3).
#
# Emergency escape (documented, loud): TC_PUSH_SKIP_GATE=1 git push
#   — prints a red banner; use only when the owner explicitly says to ship around the gate.
#
# NOTE the human push gate was REMOVED 2026-07-15 on the owner's explicit word ("убрать совсем"):
# track-coach now pushes autonomously the moment this gate is green — no explicit OK, no waiting.
# A green suite is the authorization. This hook IS the gate now; there is no conversation to verify.
# The one standing caveat (owner's word, global): a push must never regress a good README — re-shoot a
# screenshot only when the widget output changed, and keep it at least as good. See .live-spec/profile.md.

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [ "${TC_PUSH_SKIP_GATE:-0}" = "1" ]; then
  echo "!!=============================================================!!"
  echo "!!  TC_PUSH_SKIP_GATE=1 — PUSH GATE BYPASSED. This must have   !!"
  echo "!!  been the owner's explicit call. Log it in JOURNAL.md.      !!"
  echo "!!=============================================================!!"
  exit 0
fi

fail=0
echo "== track-coach push gate (pack 5-gate shape) =="

echo ""
echo "-- gate a (warning): fresh prover record --"
TODAY="$(date +%Y-%m-%d)"
if ls docs/prover/*"$TODAY"* >/dev/null 2>&1; then
  echo "   OK: a prover record dated $TODAY exists in docs/prover/."
else
  echo "   WARNING: no prover record dated $TODAY in docs/prover/."
  echo "   (Non-blocking: host cadence is per-feature + milestone audits — .live-spec/profile.md.)"
fi

echo ""
echo "-- gate b: full test suite green (this takes ~2-3 min) --"
# pytest exit codes: 0 = all passed; 1-127 = a real pytest verdict (failures / usage / collection).
# A process killed by a signal exits 128+signal (137 = SIGKILL under OS/load, 143 = SIGTERM) — the
# OS killing the run, not the suite reporting red, so it must never read as a code failure. The render
# harness now drives ONE persistent headless Chrome (scripts/headless_check.py) instead of a fresh
# browser per probe, so the suite no longer saturates the machine and a signal-kill should not happen.
# If one still does, it is reported as machine load and blocks (re-run when idle) — never auto-retried.
python3 -m pytest -q
gate_b_rc=$?
if [ "$gate_b_rc" -eq 0 ]; then
  echo "   OK: suite green."
elif [ "$gate_b_rc" -ge 128 ]; then
  echo "   INCONCLUSIVE: the run was killed by the OS (signal $((gate_b_rc - 128))) under machine load,"
  echo "   not by a failing test — unexpected with the single-browser harness. Re-run when the machine"
  echo "   is idle. (Blocking: an unverified suite never pushes.)"
  fail=1
else
  echo "   FAIL: test suite not green (pytest exit $gate_b_rc)."
  fail=1
fi

echo ""
echo "-- gate c: spec anchors owned --"
echo "   Covered by gate b (tests/test_traceability.py)."

echo ""
echo "-- gate d: matrix coverage checklist fully walked --"
if grep -qn '^\s*- \[ \]' docs/TEST_MATRIX.md; then
  echo "   FAIL: unchecked '- [ ]' boxes in docs/TEST_MATRIX.md:"
  grep -n '^\s*- \[ \]' docs/TEST_MATRIX.md | head
  fail=1
else
  echo "   OK: no unchecked boxes (checklist is the §8 prose walk)."
fi

echo ""
echo "-- gate e: prototype fence --"
if [ -d prototype ]; then
  hits="$(grep -rIl 'prototype/' --include='*.py' --include='*.html' --include='*.js' \
          --exclude-dir=prototype --exclude-dir=.git --exclude-dir=docs \
          --exclude-dir=attic --exclude-dir=data . 2>/dev/null | head)"
  if [ -n "$hits" ]; then
    echo "   FAIL: prod files reference the fenced prototype/ home:"; echo "$hits"
    fail=1
  else
    echo "   OK: fence holds."
  fi
else
  echo "   OK: no prototype/ dir — nothing fenced."
fi

echo ""
echo "-- gate f: code touched => test touched --"
if python3 scripts/guardrails.py --skip 1 >/tmp/tc_gate_f.out 2>&1; then
  echo "   OK: traceability + tests-present green."
else
  echo "   FAIL — scripts/guardrails.py output:"
  tail -30 /tmp/tc_gate_f.out
  fail=1
fi

echo ""
echo "-- gate g (warning): no derivable work parked for a greenlight --"
# NEXT_STEPS is a gitignored working doc, so this is a discipline WARNING, not a block:
# it surfaces any code-vs-spec defect still sitting behind a "wait for his greenlight"
# marker (INV-152 / host profile override 6 — a defect is derivable, the agent's own).
if python3 guardrails/check_deferral_marker.py >/tmp/tc_gate_g.out 2>&1; then
  echo "   OK: no wrongly-parked work in NEXT_STEPS."
else
  echo "   WARNING: NEXT_STEPS parks derivable work for a greenlight — unpark and do it:"
  sed -n '4,40p' /tmp/tc_gate_g.out
fi

echo ""
echo "-- gate h: compaction ratchet (his-law style at 0, redundancy only ratchets down, 2.0.0) --"
# The living docs hold ZERO scissors/negation-opener/machine-jargon errors (Alexander's language
# laws), and SPEC redundancy stays at or below its frozen floor (scripts/spec-debt-cap.json). ALL-CAPS
# and second-person stay advisory — track-coach's own voice. This is the pack's INV-164 (compaction is
# a gate, not a habit) scoped to this host. The suite (gate b) also carries it as
# tests/test_compaction_locks.py; this is the fast, explicit signal.
if python3 -m pytest tests/test_compaction_locks.py -q >/tmp/tc_gate_h.out 2>&1; then
  echo "   OK: language laws at 0, redundancy within its floor."
else
  echo "   FAIL — compaction ratchet tripped:"
  tail -20 /tmp/tc_gate_h.out
  fail=1
fi

echo ""
echo "-- gate r: ratchet caps (live-spec 2.1.0 turnkey kit, manifest-pinned) --"
# The universal register tier + redundancy stay at or below the sizes measured at adoption
# (scripts/spec-debt-cap.json, seeded by adopt/install-ratchet.sh). Growth past a seeded size reds
# tests/test_ratchet_lock.py; raising a cap means editing that generated test on purpose. This is the
# pack's canonical, source-pinned ratchet (scripts/ratchet-manifest.json); gate h above is the
# his-law-scoped sibling — both read the one cap file.
if python3 -m pytest tests/test_ratchet_lock.py -q >/tmp/tc_gate_r.out 2>&1; then
  echo "   OK: register + redundancy within their seeded caps."
else
  echo "   FAIL — ratchet caps tripped:"
  tail -20 /tmp/tc_gate_r.out
  fail=1
fi

echo ""
if [ "$fail" -ne 0 ]; then
  echo "PUSH BLOCKED — fix the failing gates above. (Emergency: TC_PUSH_SKIP_GATE=1, the owner's word only.)"
  exit 1
fi
echo "All blocking gates green — push allowed. No human gate: the push gate was removed"
echo "2026-07-15 on the owner's word — a green suite is the authorization."
exit 0
